{
  "theme": "Dark",
  "archetype": "7 (Electric & Neon) - GenZ Campus Marketplace",
  "design_principles": [
    "Mobile-first constrained desktop wrapper simulating native app (max-w-md mx-auto)",
    "Dark mode default with deep obsidian background (#050505)",
    "Glassmorphism 2.0: Surgical application on overlays (Nav, Header, Modals) with subtle tint and white/10 borders",
    "Glow Accents: Volt Green (#CCFF00) primary color with strategic CSS drop-shadows on active states",
    "Rounded Corners: Extremely friendly, tactile 24px (rounded-3xl) for cards, 16px (rounded-2xl) for buttons/inputs"
  ],
  "typography": {
    "headings": "Outfit, sans-serif (tracking-tight)",
    "body": "Manrope, sans-serif",
    "rules": [
      "H1 (Hero): text-3xl sm:text-4xl tracking-tighter font-bold",
      "H2: text-xl sm:text-2xl font-bold tracking-tight",
      "Body: text-sm sm:text-base leading-relaxed text-gray-300",
      "Overlines: text-xs uppercase tracking-[0.2em] text-gray-400"
    ]
  },
  "colors": {
    "background": "#050505",
    "surface_solid": "#121212",
    "surface_glass": "bg-white/5 backdrop-blur-xl",
    "primary": "#CCFF00",
    "primary_text": "#000000",
    "primary_glow": "shadow-[0_0_20px_rgba(204,255,0,0.3)]",
    "text_primary": "#FFFFFF",
    "text_secondary": "#A1A1AA",
    "border": "border-white/10"
  },
  "spacing_and_layout": {
    "container": "max-w-md mx-auto min-h-screen bg-[#050505] text-white relative shadow-2xl overflow-x-hidden border-x border-white/10",
    "padding": "p-4 sm:p-6",
    "gap": "gap-4 sm:gap-6",
    "radius": {
      "cards": "rounded-3xl",
      "buttons_inputs": "rounded-2xl",
      "pills": "rounded-full"
    }
  },
  "components": {
    "cards": "bg-[#121212] rounded-3xl border border-white/5 overflow-hidden",
    "bottom_nav": "fixed bottom-0 w-full max-w-md mx-auto bg-black/60 backdrop-blur-2xl border-t border-white/10 pb-safe pt-2 px-6 flex justify-between items-center z-50",
    "search_bar": "bg-white/5 border border-white/10 rounded-2xl px-4 py-3 flex items-center gap-3 backdrop-blur-md focus-within:border-[#CCFF00] focus-within:shadow-[0_0_15px_rgba(204,255,0,0.2)] transition-all",
    "buttons_primary": "bg-[#CCFF00] text-black font-bold rounded-2xl py-3 px-6 shadow-[0_0_15px_rgba(204,255,0,0.3)] hover:scale-[1.02] active:scale-[0.98] transition-all",
    "status_pills": "px-3 py-1 text-xs font-semibold rounded-full bg-white/10 text-white backdrop-blur-md border border-white/10"
  },
  "micro_animations": {
    "fade_in": "animate-in fade-in duration-300",
    "slide_up": "animate-in slide-in-from-bottom-4 duration-500",
    "hover_lift": "hover:-translate-y-1 transition-transform duration-200",
    "active_press": "active:scale-95 transition-transform duration-150"
  },
